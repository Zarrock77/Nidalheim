# API Game - core
OPENAI_API_KEY=sk-xxx

# API Game - voice pipeline (STT / LLM / TTS)
DEEPGRAM_API_KEY=your-deepgram-key
LLM_API_KEY=your-groq-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
TTS_PROVIDER=cartesia
CARTESIA_API_KEY=your-cartesia-key
CARTESIA_VOICE_ID=your-cartesia-voice-id
# Optional fallback TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# PostgreSQL
POSTGRES_USER=nidalheim
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nidalheim

# NextAuth (docs)
AUTH_SECRET=changeme-generate-a-random-secret

# JWT (shared secret between api-auth and api-game, HS256)
JWT_SECRET=changeme-generate-with-openssl-rand-base64-64
